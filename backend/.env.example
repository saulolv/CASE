# Safe local defaults. Set private values in Render; never expose them as NEXT_PUBLIC variables.
DATABASE_URL=sqlite:///./vigil.db
AGENT_MODE=gemini
AGENT_CALL_LIMIT=20

# Gemini (deploy padrão)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (preferência do case — basta trocar AGENT_MODE)
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

SESSION_SECRET=replace-with-a-long-random-secret
DEMO_OPERATOR_USERNAME=operator
DEMO_OPERATOR_PASSWORD=vigil-demo
DEMO_VIEWER_USERNAME=viewer
DEMO_VIEWER_PASSWORD=viewer-demo
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
