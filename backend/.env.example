# Safe local defaults. Set private values in Railway; never expose them as NEXT_PUBLIC variables.
DATABASE_URL=sqlite:///./vigil.db
AGENT_MODE=demo
ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=
SESSION_SECRET=replace-with-a-long-random-secret
DEMO_OPERATOR_USERNAME=operator
DEMO_OPERATOR_PASSWORD=vigil-demo
DEMO_VIEWER_USERNAME=viewer
DEMO_VIEWER_PASSWORD=viewer-demo
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
